Создай базовую структуру pytest тестов с фикстурами.

Типы фикстур:
1. `@pytest.fixture(scope="function")` - для каждого теста (по умолчанию)
2. `@pytest.fixture(scope="class")` - для каждого класса
3. `@pytest.fixture(scope="module")` - для модуля
4. `@pytest.fixture(scope="session")` - для сессии
5. `@pytest.fixture(autouse=True)` - автоматическая фикстура

Структура:
```python
import pytest
from unittest.mock import Mock, MagicMock, patch
from {{ module_name }} import {{ class_name }}

# Фикстуры уровня сессии
@pytest.fixture(scope="session")
def shared_resource():
    """Разделяемый ресурс для всех тестов"""
    resource = create_shared_resource()
    yield resource
    resource.cleanup()

# Фикстуры уровня модуля
@pytest.fixture(scope="module")
def module_data():
    """Данные для всего модуля тестов"""
    return {"key": "value"}

# Фикстуры уровня класса
@pytest.fixture(scope="class")
def class_fixture(request):
    """Фикстура для класса тестов"""
    request.cls.shared_value = "shared"
    yield
    del request.cls.shared_value

# Автоматические фикстуры
@pytest.fixture(autouse=True)
def auto_fixture():
    """Выполняется автоматически перед каждым тестом"""
    print("\nНачало теста")
    yield
    print("\nКонец теста")

@pytest.fixture
def mock_external_service():
    """Мок внешнего сервиса"""
    with patch('module.external_service') as mock:
        mock.return_value = Mock(status=200, data={'result': 'ok'})
        yield mock

class Test{{ ClassName }}:
    
    @pytest.fixture(autouse=True)
    def setup_class(self, class_fixture, mock_external_service):
        """Настройка для каждого теста в классе"""
        self.service = mock_external_service
        self.obj = {{ class_name }}(service=self.service)
        yield
        # Очистка после теста
    
    # Тестовые методы будут добавлены здесь
```

